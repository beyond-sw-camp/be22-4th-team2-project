# ============================================================
# SalesBoost 환경변수 설정 파일
# ============================================================
# 사용 방법:
#   cp .env.example .env        (Mac/Linux)
#   copy .env.example .env      (Windows CMD)
#
# .env 파일을 열어 각 값을 실제 환경에 맞게 수정하세요.
#
# ⚠️  주의: .env 파일은 절대 Git에 커밋하지 마세요! (민감 정보 포함)
#           .env.example 파일만 Git에 커밋합니다.
# ============================================================

# ------------------------------------------------------------
# [DB] MariaDB 데이터베이스 설정
# ------------------------------------------------------------
# 데이터베이스 이름
DB_DATABASE=salesboost

# MariaDB root 비밀번호 (MariaDB 컨테이너 관리용)
# ⚠️ 프로덕션에서는 반드시 강력한 비밀번호로 변경
DB_ROOT_PASSWORD=changeme_root

# ------------------------------------------------------------
# [DB] 애플리케이션 전용 DB 유저 (root 대신 사용)
# ------------------------------------------------------------
# MariaDB 이미지가 자동으로 이 유저를 생성하고
# DB_DATABASE에 대한 권한을 부여합니다.
# ⚠️ 프로덕션에서는 반드시 강력한 비밀번호로 변경
DB_USERNAME=salesboost
DB_PASSWORD=changeme_app_password

# ------------------------------------------------------------
# [Docker] MariaDB 호스트 포트 바인딩
# ------------------------------------------------------------
# Mac: 127.0.0.1 (기본, LAN에 노출 방지)
# Windows에서 외부 DB 클라이언트 접속 필요 시: 0.0.0.0
DB_HOST_BIND=127.0.0.1

# ------------------------------------------------------------
# [Backend] Spring Boot 데이터소스 설정
# ------------------------------------------------------------
# Docker Compose 환경: 호스트명은 서비스명(mariadb)
# 백엔드 직접 실행 시: jdbc:mariadb://127.0.0.1:3306/salesboost?allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_URL=jdbc:mariadb://mariadb:3306/salesboost?allowPublicKeyRetrieval=true&useSSL=false

# ------------------------------------------------------------
# [Backend] JWT 설정
# ------------------------------------------------------------
# JWT 서명 시크릿 키 (32바이트 이상, 프로덕션에서는 반드시 변경)
# 강력한 키 생성 예시: openssl rand -base64 48
APP_JWT_SECRET=change-this-to-very-long-secret-key-at-least-32bytes

# ------------------------------------------------------------
# [Backend] CORS 설정
# ------------------------------------------------------------
# 허용할 오리진 목록 (쉼표로 구분, 공백 없이)
# 로컬 개발: http://localhost,http://localhost:5173
# 프로덕션: 실제 서비스 도메인으로 변경
APP_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# [Monitoring] Grafana 관리자 계정
# ------------------------------------------------------------
# Grafana 웹 UI 로그인용 (http://localhost:3001)
# ⚠️ 프로덕션에서는 반드시 강력한 비밀번호로 변경
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# ------------------------------------------------------------
# [Monitoring] Logstash 연결 설정
# ------------------------------------------------------------
# Docker Compose 환경: logstash:5001 (서비스명으로 접근)
# Logstash를 사용하지 않을 경우 빈 값으로 설정
LOGSTASH_HOST=logstash:5001
